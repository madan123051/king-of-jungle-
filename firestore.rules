rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read/write for authenticated users in their own user document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      // Allow reading public profile info
      allow read: if true;
      
      // Levels subcollection - user can read/write their own
      match /levels/{levelId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Config can be read by everyone, written only by admin
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
    
    // Referrals can be read by everyone
    match /referrals/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Error logs can be written by anyone
    match /error_logs/{document=**} {
      allow create: if true;
      allow read: if request.auth.token.admin == true;
    }
    
    // Leaderboard data is public read-only
    match /leaderboard/{document=**} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }
  }
}
